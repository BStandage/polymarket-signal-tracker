# Copy this file to `.env` (gitignored) and fill in real values.
# Never commit `.env`.

# ---- Discord webhook (required for notifications) ----
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_HERE

# ---- Mode: "paper" (default) or "live" ----
# paper = simulates trades, no real orders placed, fully safe
# live  = places REAL orders on Polymarket CLOB. Requires wallet key.
MODE=paper

# ---- Polymarket wallet (required only in LIVE mode) ----
# Your Polygon wallet's private key (0x...64 hex chars).
# NEVER paste this anywhere but this local file. If it leaks, funds are gone.
# POLYMARKET_PRIVATE_KEY=0x...

# The address that funds your trades (usually same as wallet address).
# POLYMARKET_FUNDER_ADDRESS=0x...

# ---- Optional tuning (defaults shown) ----
# STARTING_BANKROLL=100.00
# MAX_POSITION_SIZE=12.00
# MAX_CONCURRENT=3
# DAILY_LOSS_LIMIT=25.00
# BANKROLL_FLOOR=50.00
# MAX_DRIFT=0.02
# MIN_WHALE_SIZE=1000
# MIN_ENTRY=0.30
# MAX_ENTRY=0.65
# STOP_LOSS_PCT=-0.30
# TAKE_PROFIT_PCT=0.40
# MAX_HOLD_DAYS=7
# LOOP_INTERVAL=60

# ---- Notification verbosity ----
# NOTIFY_SKIPS=false       # ping for every filtered-out signal (noisy)
# NOTIFY_HEARTBEAT=true    # periodic bankroll/P&L summary
